# Supabase client configuration. The anon key is public by design; never add
# the Supabase service_role key to this app or to NEXT_PUBLIC_* variables.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional market data providers. These are server-only and should be stored
# as encrypted Vercel environment variables, not exposed with NEXT_PUBLIC_.
FINNHUB_API_KEY=
FMP_API_KEY=
ALPHA_VANTAGE_API_KEY=
TWELVE_DATA_API_KEY=

# Required only when saving user-specific market data API keys from Settings.
# Use a long random server-only secret.
MARKET_DATA_SECRET=
